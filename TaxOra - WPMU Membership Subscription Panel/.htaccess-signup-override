# Custom signup page override
# This file should be copied to your WordPress root directory

# Redirect wp-signup.php to custom signup page
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirect wp-signup.php to custom signup (unless custom=false)
    RewriteCond %{QUERY_STRING} !(custom=false)
    RewriteRule ^wp-signup\.php$ /signup [R=301,L]
</IfModule>

# Alternative: Direct PHP handler for wp-signup.php
<Files "wp-signup.php">
    # This will load our custom template instead
    php_value auto_prepend_file "/wp-content/plugins/TaxOra - WPMU Membership Subscription Panel/wp-signup-override.php"
</Files>
