# ---------------------------------------------------------------------------
# OraBooks Production Deploy Configuration
#
# Copy this file to .env.deploy and fill in your managed WP host details.
# Most managed WordPress hosts (WP Engine, Kinsta, Cloudways, SiteGround)
# provide SFTP/SSH access for deploying plugin files.
# ---------------------------------------------------------------------------

# SFTP / SSH connection
DEPLOY_HOST=sftp.your-host.com
DEPLOY_PORT=22
DEPLOY_USER=your-username

# Path to the plugin root on the server, e.g.:
#   WP Engine:  ~/wp-content/plugins/OraBooks\ Lean\ MVP/
#   Kinsta:     /www/your-site/public/wp-content/plugins/OraBooks\ Lean\ MVP/
#   Cloudways:  /home/master/applications/your-app/public_html/wp-content/plugins/OraBooks\ Lean\ MVP/
DEPLOY_TARGET_DIR=/path/to/wp-content/plugins/OraBooks Lean MVP/

# Local path to the built assets (relative to this file)
BUILD_OUTPUT_DIR=../assets/react
